# Public (browser-safe) — used by the dashboard to read movies/jobs with the user's login.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...

# Server-only — used by the /api/runs route to build job chains. NEVER prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_KEY=eyJ...service-role...
